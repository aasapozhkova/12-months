@startuml
!theme reddress-darkred
skinparam classAttributeIconSize 0

' --- Иерархия персонажей ---
abstract class Персонаж {
    + имя: String
    + характер: String
    + взаимодействовать(цель: Подснежники)
}

abstract class БратецМесяц extends Персонаж {
    + сезон: String
    + сменитьСезон()
}

class Январь extends БратецМесяц {
    + сезон = "Зима"
    + силаМороза = 100
}

class Февраль extends БратецМесяц {
    + сезон = "Зима"
    + метель = 80
}

class Март extends БратецМесяц {
    + сезон = "Весна"
    + капель = 50
}

class Апрель extends БратецМесяц {
    + сезон = "Весна"
    + тепло = 70
}

class Падчерица extends Персонаж {
    + трудолюбие 100
    + доброта 100
    + искатьЦветы()
    + даритьПодарки()
}

class Королева extends Персонаж {
    + капризность 90
    + приказывать()
}

class Мачеха extends Персонаж {
    + жестокость 80
    + послатьВЛес()
}

class Дочь extends Персонаж {
    + лень 90
    + жадность 90
}

' --- Иерархия ресурсов ---
abstract class Подснежники {
    + количество: int
    + свежесть: int
    + состояние: String = "растут"
}

class Цветы extends Подснежники {
    + цвет: String = "белый"
    + аромат: String = "нежный"
}

' --- Управляющий класс ---
class Природа {
    + текущийСезон: String
    + сменитьСезон(месяц: БратецМесяц)
    + выраститьЦветы()
}

' --- СВЯЗИ ---
Природа "1" -- "12" БратецМесяц : управляет >
БратецМесяц --> Подснежники : выращивает >
Падчерица --> Природа : просит помощи >
Падчерица ..> Подснежники : находит >

Мачеха --> Падчерица : отправляет >
Королева --> Природа : требует >

' --- Заметки ---
note right of Падчерица::искатьЦветы
  **Поиск подснежников**
  Ищет цветы в зимнем лесу,
  встречает братьев-месяцев
end note

note bottom of Апрель
  Только Апрель может 
  вырастить подснежники
end note

note right of Природа::сменитьСезон
  **Смена сезона**
  Месяцы передают друг другу
  жезл, меняя время года
end note

@enduml
